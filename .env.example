# Healthclaim Guardian Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# DATABRICKS AUTHENTICATION
# ===========================================

# Databricks workspace URL (required)
# Format: https://<workspace-id>.<cloud>.databricks.net
DATABRICKS_HOST=https://your-workspace-id.azuredatabricks.net

# Databricks Personal Access Token (optional if running on Databricks)
# Generate at: https://docs.databricks.com/dev-tools/auth/pat.html
DATABRICKS_TOKEN=your-personal-access-token

# Unity Catalog configuration
DATABRICKS_CATALOG=healthclaim_guardian
DATABRICKS_SCHEMA=default

# ===========================================
# PIPELINE CONFIGURATION
# ===========================================

# Number of records to generate (for synthetic data)
# Default: 10000, Production: 1000000
PIPELINE_NUM_RECORDS=10000

# Fraction of records with data quality issues (for testing)
# Range: 0.0 to 1.0, Default: 0.10 (10%)
PIPELINE_DIRTY_RATIO=0.10

# Maximum allowed billed amount before filtering as outlier
# Default: 50000.0 ($50,000)
PIPELINE_MAX_BILLED=50000.0

# ===========================================
# ML MODEL CONFIGURATION
# ===========================================

# Number of clusters for K-Means algorithm
# Default: 3, Range: 2-10
ML_N_CLUSTERS=3

# Random seed for reproducibility
# Default: 42
ML_RANDOM_STATE=42

# MLflow experiment path (relative to workspace)
MLFLOW_EXPERIMENT_PATH=/healthclaim_fraud

# Model registry name
MODEL_REGISTRY_NAME=healthclaim_fraud_detector

# ===========================================
# ANOMALY DETECTION CONFIGURATION
# ===========================================

# Minimum ratio threshold for flagging anomalies
# Claims with ratio > this value are flagged
# Default: 1.1 (10% above hospital average)
ANOMALY_THRESHOLD=1.1

# Minimum number of clusters required for anomaly detection
# If fewer clusters found, anomaly detection is skipped
# Default: 2
MIN_CLUSTERS_FOR_ANOMALY=2

# ===========================================
# LOGGING CONFIGURATION
# ===========================================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json, text
LOG_FORMAT=text

# ===========================================
# ENVIRONMENT SPECIFIC SETTINGS
# ===========================================

# Environment name: dev, staging, prod
ENVIRONMENT=dev

# Enable/disable model training
# Set to 'false' for inference-only runs
RUN_TRAINING=true

# Enable/disable data validation
# Set to 'false' to skip validation (not recommended)
RUN_VALIDATION=true

# ===========================================
# SECRETS CONFIGURATION (Advanced)
# ===========================================

# Databricks Secrets scope name
# Leave default unless using custom scope
SECRETS_SCOPE=healthclaim_guardian

# Azure Key Vault URL (optional, for Azure-based secrets)
# AZURE_KEYVAULT_URL=https://your-vault.vault.azure.net/

# AWS Secrets Manager ARN (optional, for AWS-based secrets)
# AWS_SECRET_ARN=arn:aws:secretsmanager:region:account:secret:name
